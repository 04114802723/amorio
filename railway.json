{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm --prefix server ci",
    "watchPatterns": [
      "/server/**",
      "/railway.json"
    ]
  },
  "deploy": {
    "startCommand": "npm --prefix server start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
